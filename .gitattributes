# Auto-detect text files and normalize line endings
* text=auto eol=lf

# C# / .NET source files - keep LF in repo, native on checkout
*.cs        text diff=csharp
*.csproj    text
*.slnx      text
*.sln       text eol=crlf
*.props     text
*.targets   text
*.config    text
*.json      text
*.xml       text
*.md        text
*.yml       text
*.yaml      text

# Windows-only scripts must stay CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Shell scripts must stay LF
*.sh        text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.zip       binary
